---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---
<BaseLayout>
  <div class="max-w-4xl mx-auto px-6">

    <!-- Hero -->
    <section class="py-28 text-center">
      <div class="inline-block text-xs font-semibold tracking-widest uppercase text-purple-400
                  bg-violet-500/10 border border-violet-500/20 rounded-full px-4 py-1.5 mb-8">
        Quantum · Physics · Computation
      </div>
      <h1 class="text-6xl font-bold tracking-tight leading-none mb-6
                 bg-gradient-to-br from-violet-400 via-purple-400 to-pink-400
                 bg-clip-text [-webkit-background-clip:text] [-webkit-text-fill-color:transparent]">
        THE PATH INTEGRAL
      </h1>
      <p class="text-zinc-400 text-xl max-w-xl mx-auto leading-relaxed">
        Articles and interactive tools for understanding quantum computing,
        physics, and computational science.
      </p>

      <div class="flex flex-wrap gap-4 justify-center mt-10">
        <a href="/articles"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-medium text-sm
                  bg-violet-600/80 text-white border border-violet-500/40
                  hover:bg-violet-600 hover:shadow-[0_0_20px_rgba(124,58,237,0.35)] transition-all">
          Read Articles
        </a>
        <a href="https://projects.thepathintegral.org"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-medium text-sm
                  bg-white/5 text-zinc-300 border border-white/10
                  hover:bg-white/10 hover:text-white transition-all">
          Interactive Projects
        </a>
      </div>
    </section>

    <!-- Latest Articles -->
    {articles.length > 0 && (
      <section class="pb-24">
        <div class="flex items-baseline gap-3 mb-8">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Latest</h2>
          <span class="text-xs font-mono text-zinc-700">{articles.length} articles</span>
        </div>

        <div class="flex flex-col gap-4">
          {articles.map((article) => (
            <a href={`/articles/${article.slug}`}
               class="group flex flex-col sm:flex-row sm:items-center justify-between
                      p-5 rounded-2xl border border-violet-500/10 bg-violet-500/[0.03]
                      hover:bg-violet-500/[0.07] hover:border-violet-500/25
                      transition-all duration-200">
              <div>
                <h3 class="font-semibold text-zinc-100 group-hover:text-white transition-colors mb-1">
                  {article.data.title}
                </h3>
                {article.data.description && (
                  <p class="text-sm text-zinc-500 line-clamp-1">{article.data.description}</p>
                )}
              </div>
              <div class="flex items-center gap-3 mt-3 sm:mt-0 sm:ml-6 shrink-0">
                {article.data.tags?.slice(0, 2).map((tag: string) => (
                  <span class="text-xs font-mono px-2 py-0.5 rounded-full
                               bg-violet-500/10 text-violet-400 border border-violet-500/20">
                    {tag}
                  </span>
                ))}
                <span class="text-zinc-600 text-sm font-mono ml-2">→</span>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-6 text-right">
          <a href="/articles" class="text-sm text-violet-400 hover:text-violet-300 transition-colors">
            All articles →
          </a>
        </div>
      </section>
    )}

    <!-- Projects teaser -->
    <section class="pb-24">
      <div class="flex items-baseline gap-3 mb-8">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Interactive Projects</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="https://projects.thepathintegral.org/vqe/"
           target="_blank" rel="noopener"
           class="group p-5 rounded-2xl border border-violet-500/10 bg-violet-500/[0.03]
                  hover:bg-violet-500/[0.07] hover:border-violet-500/25 transition-all">
          <div class="text-2xl mb-3">⚛️</div>
          <h3 class="font-semibold text-zinc-100 group-hover:text-white mb-1">VQE Explorer</h3>
          <p class="text-sm text-zinc-500">
            Step-by-step visualization of the Variational Quantum Eigensolver running real Qiskit simulations.
          </p>
        </a>
        <a href="https://xai-for-structure-walls.streamlit.app/"
           target="_blank" rel="noopener"
           class="group p-5 rounded-2xl border border-violet-500/10 bg-violet-500/[0.03]
                  hover:bg-violet-500/[0.07] hover:border-violet-500/25 transition-all">
          <div class="text-2xl mb-3">🏗️</div>
          <h3 class="font-semibold text-zinc-100 group-hover:text-white mb-1">XAI for Structural Walls</h3>
          <p class="text-sm text-zinc-500">
            Interpretable ML for predicting reinforced concrete wall shear capacity.
          </p>
        </a>
      </div>
      <div class="mt-6 text-right">
        <a href="https://projects.thepathintegral.org" class="text-sm text-violet-400 hover:text-violet-300 transition-colors">
          All projects →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
