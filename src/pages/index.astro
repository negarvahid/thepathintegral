---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const projects = [
  {
    href: "https://projects.thepathintegral.org/vqe/",
    icon: "⚛️",
    title: "VQE Explorer",
    description: "Step-by-step visualization of the Variational Quantum Eigensolver running real Qiskit simulations.",
    external: true,
  },
  {
    href: "https://xai-for-structure-walls.streamlit.app/",
    icon: "🏗️",
    title: "XAI for Structural Walls",
    description: "Interpretable ML for predicting reinforced concrete wall shear capacity.",
    external: true,
  },
];
---
<BaseLayout>
  <div class="max-w-4xl mx-auto px-6">

    <!-- Hero -->
    <section class="py-24 text-center">
      <img src="/logo-mark-transparent.svg" alt="The Path Integral" class="w-16 h-16 mx-auto mb-6 opacity-90" />
      <h1 class="text-6xl font-bold tracking-tight leading-none mb-6
                 bg-gradient-to-br from-violet-400 via-purple-400 to-pink-400
                 bg-clip-text [-webkit-background-clip:text] [-webkit-text-fill-color:transparent]">
        THE PATH INTEGRAL
      </h1>
      <p class="text-zinc-400 text-xl max-w-xl mx-auto leading-relaxed">
        Articles and interactive tools for understanding quantum computing,
        computational chemistry, and computational science.
      </p>

      <div class="flex flex-wrap gap-3 justify-center mt-10">
        <a href="/articles"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-medium text-sm
                  bg-violet-600/80 text-white border border-violet-500/40
                  hover:bg-violet-600 hover:shadow-[0_0_20px_rgba(124,58,237,0.35)] transition-all">
          📚 Articles
        </a>
        <a href="https://youtube.com/@thepathintegral" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-medium text-sm
                  bg-white/5 text-zinc-300 border border-white/10
                  hover:bg-white/10 hover:text-white transition-all">
          ▶️ YouTube
        </a>
        <a href="https://projects.thepathintegral.org"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-medium text-sm
                  bg-white/5 text-zinc-300 border border-white/10
                  hover:bg-white/10 hover:text-white transition-all">
          ⚛️ Projects
        </a>
      </div>
    </section>

    <!-- ── Row 1: Latest Articles ── -->
    <section class="pb-20">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-baseline gap-3">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Latest Articles</h2>
        </div>
        <a href="/articles" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
          View all →
        </a>
      </div>

      {articles.length === 0 ? (
        <div class="p-8 rounded-2xl border border-dashed border-zinc-800 text-center text-zinc-600 text-sm">
          Articles coming soon.
        </div>
      ) : (
        <div class="flex flex-col gap-3">
          {articles.map((article) => (
            <a href={`/articles/${article.slug}`}
               class="group flex flex-col sm:flex-row sm:items-center justify-between
                      p-5 rounded-2xl border border-violet-500/10 bg-violet-500/[0.03]
                      hover:bg-violet-500/[0.07] hover:border-violet-500/25 transition-all">
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-zinc-100 group-hover:text-white transition-colors mb-1">
                  {article.data.title}
                </h3>
                {article.data.description && (
                  <p class="text-sm text-zinc-500 truncate">{article.data.description}</p>
                )}
              </div>
              <div class="flex items-center gap-2 mt-3 sm:mt-0 sm:ml-6 shrink-0">
                {article.data.tags?.slice(0, 2).map((tag: string) => (
                  <span class="text-xs font-mono px-2 py-0.5 rounded-full
                               bg-violet-500/10 text-violet-400 border border-violet-500/20">
                    {tag}
                  </span>
                ))}
                <span class="text-zinc-600 group-hover:text-violet-400 transition-colors text-sm ml-1">→</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- ── Row 2: Projects ── -->
    <section class="pb-24">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Interactive Projects</h2>
        <a href="https://projects.thepathintegral.org"
           class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
          All projects →
        </a>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        {projects.map((p) => (
          <a href={p.href}
             target={p.external ? "_blank" : undefined}
             rel={p.external ? "noopener" : undefined}
             class="group p-5 rounded-2xl border border-violet-500/10 bg-violet-500/[0.03]
                    hover:bg-violet-500/[0.07] hover:border-violet-500/25 transition-all">
            <div class="text-2xl mb-3">{p.icon}</div>
            <h3 class="font-semibold text-zinc-100 group-hover:text-white mb-1.5 transition-colors">
              {p.title}
            </h3>
            <p class="text-sm text-zinc-500 leading-relaxed">{p.description}</p>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
