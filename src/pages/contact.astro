---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="About | The Path Integral">
  <div class="max-w-2xl mx-auto px-6 py-24">

    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-violet-400 mb-3">
        Hi, I'm
      </p>
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-none mb-6
                 bg-gradient-to-br from-violet-400 via-purple-400 to-pink-400
                 bg-clip-text [-webkit-background-clip:text] [-webkit-text-fill-color:transparent]">
        Negar Vahid
      </h1>
    </div>

    <!-- Bio -->
    <div class="space-y-5 text-lg text-zinc-300 leading-relaxed mb-12">
      <p>
        I'm finishing up my master's in computational science with a minor in
        quantum algorithms.
      </p>
      <p>
        I'm fascinated with our universe, and I write about the things I learn
        along the way, from my university work, my content creation gigs, and
        my personal projects.
      </p>
      <p class="text-zinc-400">
        Want to chat or request a topic? I'd love to hear from you.
      </p>
    </div>

    <!-- Contact links -->
    <div class="grid sm:grid-cols-2 gap-3">
      <a href="mailto:contact@thepathintegral.org"
         class="group flex items-center gap-3 px-5 py-4 rounded-2xl
                border border-violet-500/15 bg-violet-500/[0.04]
                hover:bg-violet-500/[0.10] hover:border-violet-500/35 transition-all">
        <span class="text-2xl">✉️</span>
        <div class="min-w-0">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-zinc-500 mb-0.5">
            Email
          </p>
          <p class="font-mono text-sm text-violet-300 group-hover:text-violet-200 truncate">
            contact@thepathintegral.org
          </p>
        </div>
      </a>

      <a href="https://www.linkedin.com/in/negar-vahid/" target="_blank" rel="noopener"
         class="group flex items-center gap-3 px-5 py-4 rounded-2xl
                border border-violet-500/15 bg-violet-500/[0.04]
                hover:bg-violet-500/[0.10] hover:border-violet-500/35 transition-all">
        <span class="text-2xl">💼</span>
        <div class="min-w-0">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-zinc-500 mb-0.5">
            LinkedIn
          </p>
          <p class="text-sm text-violet-300 group-hover:text-violet-200 truncate">
            negar-vahid
          </p>
        </div>
      </a>
    </div>

    <!-- Secondary links -->
    <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-sm text-zinc-500">
      <a href="https://youtube.com/@thepathintegral" target="_blank" rel="noopener"
         class="hover:text-violet-400 transition-colors">
        ▶ YouTube
      </a>
      <a href="https://github.com/negarvahid" target="_blank" rel="noopener"
         class="hover:text-violet-400 transition-colors">
        ⌘ GitHub
      </a>
      <a href="https://www.linkedin.com/company/thepathintegral/" target="_blank" rel="noopener"
         class="hover:text-violet-400 transition-colors">
        ✦ The Path Integral on LinkedIn
      </a>
    </div>

  </div>
</BaseLayout>
