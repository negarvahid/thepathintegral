---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Contact | The Path Integral">
  <div class="max-w-xl mx-auto px-6 py-24 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-white mb-4">Get in touch</h1>
    <p class="text-zinc-400 mb-10">
      Questions, collaborations, or just want to talk quantum? Find me here:
    </p>
    <div class="flex flex-col gap-4">
      <a href="https://www.linkedin.com/company/thepathintegral/" target="_blank" rel="noopener"
         class="flex items-center justify-center gap-3 px-6 py-4 rounded-xl
                bg-violet-500/10 text-violet-300 border border-violet-500/20
                hover:bg-violet-500/20 hover:border-violet-500/40 transition-all font-medium">
        LinkedIn
      </a>
      <a href="https://youtube.com/@thepathintegral" target="_blank" rel="noopener"
         class="flex items-center justify-center gap-3 px-6 py-4 rounded-xl
                bg-violet-500/10 text-violet-300 border border-violet-500/20
                hover:bg-violet-500/20 hover:border-violet-500/40 transition-all font-medium">
        YouTube
      </a>
      <a href="https://github.com/negarvahid" target="_blank" rel="noopener"
         class="flex items-center justify-center gap-3 px-6 py-4 rounded-xl
                bg-violet-500/10 text-violet-300 border border-violet-500/20
                hover:bg-violet-500/20 hover:border-violet-500/40 transition-all font-medium">
        GitHub
      </a>
    </div>
  </div>
</BaseLayout>
